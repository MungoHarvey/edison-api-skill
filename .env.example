# Edison Scientific API key — required
# Get yours from: https://platform.edisonscientific.com/profile
EDISON_PLATFORM_API_KEY=your_api_key_here

# Optional convenience variable — NOT read automatically by any Edison script.
# Use it yourself in --output arguments: --output $EDISON_OUTPUT_DIR/result.md
# EDISON_OUTPUT_DIR=/Users/yourname/Documents/Edison-Outputs
